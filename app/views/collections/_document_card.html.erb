<%= tag.div class: 'bg-gradient-to-br from-white to-slate-200 rounded-xl p-6 border border-border shadow-sm hover:shadow-md transition-all duration-200 cursor-pointer' do %>
  <%= tag.div class: 'flex items-start justify-between mb-4' do %>
    <%= tag.div class: 'size-12 text-emerald-700 bg-emerald-100 rounded-lg flex items-center justify-center group-hover:bg-primary/20 transition-colors' do %>
      <%= heroicon icon, options: { class: 'size-8 ' } %>
    <% end %>

    <%= tag.button class: 'font-bold p-1 hover:bg-gray-200 rounded cursor-pointer' do %>
      <%= heroicon 'ellipsis-vertical', options: { class: 'size-4' } %>
    <% end %>
  <% end %>

  <%= link_to document_path(document) do %>
    <%= tag.h3 document.title, class: 'text-lg font-semibold text-foreground mb-2 hover:text-emerald-600' %>
  <% end %>

  <%= tag.p 'Complete API reference with endpoints, authentication, and examples', class: 'text-sm text-muted-foreground mb-4' %>

  <%= tag.div class: 'flex items-center justify-between' do %>
    <%= tag.div class: 'flex items-center space-x-4 text-xs text-muted-foreground' do %>
      <%= tag.span class: 'flex items-center space-x-1' do %>
        <%= heroicon 'clock', options: { class: 'size-3' } %>
        <%= tag.span time_since_updated %>
      <% end %>
      <%= tag.span class: 'flex items-center space-x-1' do %>
        <%= heroicon 'cloud-arrow-up', options: { class: 'size-3' } %>
        <%= tag.span human_size(document.size_bytes) %>
      <% end %>
    <% end %>

    <%= tag.span document.document_type.upcase, class: 'text-xs bg-emerald-100 text-primary px-2 py-1 rounded-full' %>
  <% end %>
<% end %>
